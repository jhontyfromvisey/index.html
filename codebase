<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Riddhima Goel | Founder, Designer & Researcher</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

:root{
    --bg:#0a0a0a;
    --card:#141414;
    --text:#ffffff;
    --muted:#b4b4b4;
    --accent:#7c5cff;
    --border:#252525;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:'Inter',sans-serif;
    background:var(--bg);
    color:var(--text);
    line-height:1.7;
}

.container{
    width:min(1100px,90%);
    margin:auto;
}

nav{
    position:fixed;
    top:0;
    width:100%;
    backdrop-filter:blur(20px);
    background:rgba(10,10,10,0.8);
    border-bottom:1px solid var(--border);
    z-index:100;
}

.nav-content{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 0;
}

.logo{
    font-weight:800;
    font-size:1.1rem;
}

.nav-links{
    display:flex;
    gap:28px;
}

.nav-links a{
    color:var(--muted);
    text-decoration:none;
    transition:0.3s;
}

.nav-links a:hover{
    color:white;
}

.hero{
    min-height:100vh;
    display:flex;
    align-items:center;
}

.hero-content{
    max-width:850px;
}

.tag{
    display:inline-block;
    background:rgba(124,92,255,0.15);
    color:#b8a8ff;
    padding:8px 14px;
    border-radius:999px;
    margin-bottom:24px;
    font-size:0.9rem;
}

h1{
    font-size:clamp(3rem,7vw,5.5rem);
    line-height:1;
    margin-bottom:24px;
}

.hero p{
    color:var(--muted);
    font-size:1.2rem;
    max-width:750px;
}

.highlight{
    color:var(--accent);
}

.cta{
    margin-top:40px;
    display:flex;
    gap:16px;
    flex-wrap:wrap;
}

.btn{
    padding:14px 22px;
    border-radius:12px;
    text-decoration:none;
    font-weight:600;
}

.primary{
    background:var(--accent);
    color:white;
}

.secondary{
    border:1px solid var(--border);
    color:white;
}

section{
    padding:100px 0;
}

.section-title{
    font-size:2.2rem;
    margin-bottom:40px;
}

.about{
    display:grid;
    grid-template-columns:1.2fr 1fr;
    gap:50px;
}

.card{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:20px;
    padding:28px;
}

.card p{
    color:var(--muted);
}

.timeline{
    display:flex;
    flex-direction:column;
    gap:24px;
}

.timeline-item{
    border-left:2px solid var(--accent);
    padding-left:22px;
}

.timeline-item h3{
    margin-bottom:6px;
}

.timeline-item span{
    color:var(--muted);
    font-size:0.95rem;
}

.skills{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
}

.skill-card{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:18px;
    padding:24px;
}

.skill-card h4{
    margin-bottom:12px;
}

.skill-card p{
    color:var(--muted);
}

.quote{
    text-align:center;
    font-size:1.8rem;
    max-width:850px;
    margin:auto;
    font-weight:600;
}

.quote span{
    color:var(--accent);
}

footer{
    padding:60px 0;
    border-top:1px solid var(--border);
    text-align:center;
    color:var(--muted);
}

@media(max-width:800px){

    .about{
        grid-template-columns:1fr;
    }

    .nav-links{
        display:none;
    }

    h1{
        font-size:3.2rem;
    }
}
</style>
</head>

